# Required
DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus
REDIS_URL=redis://localhost:6379

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_ENCRYPTION_KEY=your_64_hex_chars_here

# Dashboard admin password (set anything you want)
ADMIN_PASSWORD=change_me_strong_password

# Optional
PORT=3000
LOG_LEVEL=info

# Abuse guard — DoS/abuse backstop, NOT a throughput cap.
# Real throughput is controlled per-key by provider RPM/TPM inside the pool.
# Size this above your busiest single credential's expected rate. Per credential
# (each team key = its own bucket). Default 12000/min (200 req/s). See README.
ABUSE_RATE_LIMIT_MAX=12000
ABUSE_RATE_LIMIT_WINDOW=1 minute
